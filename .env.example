# ==============================================================================
# MedTech Production-Grade Environment Configuration Variables
# ==============================================================================
# Copy this file to .env and configure secret keys prior to microservices deploy

# Application Settings
NODE_ENV=production
PORT=3000
API_PREFIX=/api/v1

# Security & Authentication (JWT)
JWT_SECRET=your_jwt_access_secret_key_change_in_production_min_64_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_in_production_min_64_chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Databases
MONGO_ROOT_USER=medtech
MONGO_ROOT_PASS=medtech_secret_key_mongo
MONGO_URI=mongodb://medtech:medtech_secret_key_mongo@mongodb:27017/medtech_db?authSource=admin

# Vector Search (Qdrant)
QDRANT_URL=http://qdrant:6333

# Caching & Session Store (Redis)
REDIS_PASSWORD=medtech_secure_redis_pwd
REDIS_URL=redis://:medtech_secure_redis_pwd@redis:6379

# Queue Management & Message Broker (RabbitMQ)
RABBITMQ_USER=medtech
RABBITMQ_PASS=medtech_rabbitmq_pwd
RABBITMQ_URL=amqp://medtech:medtech_rabbitmq_pwd@rabbitmq:5672

# High-Speed Search (Elasticsearch)
ELASTICSEARCH_NODE=http://elasticsearch:9200

# AI Models (HuggingFace Inference API)
HUGGINGFACE_API_KEY=hf_your_huggingface_inference_api_key_goes_here

# PaddleOCR OCR Microservice
PADDLEOCR_SERVICE_URL=http://paddleocr-service:8000

# Cloud Object Storage (Cloudflare R2 or AWS S3)
S3_ENDPOINT=https://your-cloudflare-r2-account-id.r2.cloudflarestorage.com
S3_BUCKET_NAME=medtech-patient-reports
S3_ACCESS_KEY=your_r2_or_s3_access_key
S3_SECRET_KEY=your_r2_or_s3_secret_key
S3_PUBLIC_DOMAIN=https://static.medtech.com

# Push Notifications (Firebase Cloud Messaging)
FIREBASE_CREDENTIALS_JSON_PATH=/path/to/firebase-adminsdk-credentials.json
