# ============================================
# Patient Service - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# Server
PORT=3009
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb://mediflow:mediflow_secret@localhost:27017/patient_db?authSource=admin

# JWT (auth-service ile aynı secret kullanılmalı)
JWT_SECRET=mediflow_jwt_secret_key_change_in_production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
